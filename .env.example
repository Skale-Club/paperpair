# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:6778"
NEXT_PUBLIC_SITE_URL="https://paperpaired.vercel.app"

# Admin credentials (used for first-time bootstrap via scripts/bootstrap-supabase.mjs)
ADMIN_ALLOWED_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Postgres (Prisma) ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# POSTGRES_PRISMA_URL     → Transaction pooler (port 6543) — used by the app
# POSTGRES_URL_NON_POOLING → Session pooler (port 5432) — used by Prisma migrations
POSTGRES_PRISMA_URL="postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
POSTGRES_URL_NON_POOLING="postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── AI encryption ────────────────────────────────────────────────────────────
# Master key used to encrypt AI provider keys before storing them in the DB.
# Generate with: openssl rand -hex 32
# WARNING: changing this value makes all existing stored AI keys unreadable.
AI_KEYS_ENCRYPTION_SECRET="generate-with-openssl-rand-hex-32"

# ─── Keepalive ────────────────────────────────────────────────────────────────
# Used by GET /api/keepalive to authenticate the GitHub Actions cron ping.
# Generate with: openssl rand -hex 24
# Set as KEEPALIVE_SECRET in GitHub repo secrets, and KEEPALIVE_URL as the production URL.
KEEPALIVE_SECRET="generate-with-openssl-rand-hex-24"
