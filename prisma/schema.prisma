generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PageContent {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum StepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model UserProfile {
  id        String   @id @default(cuid())
  authId    String   @unique
  email     String   @unique
  fullName  String?
  avatarUrl String?
  role         Role     @default(USER)
  tier         String   @default("free")
  googleApiKey String?
  requireBiometricsForSensitiveDocs Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Spouse viewer linking
  viewerOfId   String?
  viewerOf     UserProfile?  @relation("SpouseViewer", fields: [viewerOfId], references: [id])
  viewers      UserProfile[] @relation("SpouseViewer")

  caseSteps     CaseStep[]
  spouseInvites SpouseInvite[]
}

model SpouseInvite {
  id            String   @id @default(cuid())
  token         String   @unique @default(cuid())
  primaryUserId String   @unique
  spouseEmail   String
  accepted      Boolean  @default(false)
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  primaryUser UserProfile @relation(fields: [primaryUserId], references: [id], onDelete: Cascade)
}

model CaseStep {
  id            String     @id @default(cuid())
  userProfileId String
  stepSlug      String
  status        StepStatus @default(NOT_STARTED)
  data          String     @default("{}")
  updatedAt     DateTime   @updatedAt
  createdAt     DateTime   @default(now())

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, stepSlug])
}
